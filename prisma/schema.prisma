generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  role         Role
  name         String
  email        String   @unique
  phone        String?
  image        String?
  passwordHash String?
  createdAt    DateTime @default(now())

  jobs         Job[]         @relation("HirerJobs")
  applications Application[]
  reviews      Review[]      @relation("UserReviews")
  messages     Message[]     @relation("UserMessages")
  Booking      Booking[]
}

model Job {
  id      String @id @default(cuid())
  hirerId String
  hirer   User   @relation("HirerJobs", fields: [hirerId], references: [id])

  title       String
  category    String
  description String
  budgetType  BudgetType
  amount      Int
  whenText    String
  address     String
  status      JobStatus  @default(OPEN)
  createdAt   DateTime   @default(now())

  applications Application[]
  booking      Booking?
  messages     Message[]
}

model Application {
  id    String @id @default(cuid())
  jobId String
  job   Job    @relation(fields: [jobId], references: [id])

  workerId String
  worker   User   @relation(fields: [workerId], references: [id])

  note      String?
  createdAt DateTime  @default(now())
  status    AppStatus @default(PENDING)
}

model Booking {
  id    String @id @default(cuid())
  jobId String @unique
  job   Job    @relation(fields: [jobId], references: [id])

  workerId String
  worker   User   @relation(fields: [workerId], references: [id])

  agreedRate      Int
  createdAt       DateTime      @default(now())
  status          BookingStatus @default(ACCEPTED)
  paymentIntentId String?
}

model Review {
  id        String  @id @default(cuid())
  bookingId String
  rating    Int
  comment   String?

  fromUserId String
  fromUser   User   @relation("UserReviews", fields: [fromUserId], references: [id])
  toUserId   String

  createdAt DateTime @default(now())
}

model Message {
  id    String @id @default(cuid())
  jobId String
  job   Job    @relation(fields: [jobId], references: [id])

  fromUserId String
  fromUser   User   @relation("UserMessages", fields: [fromUserId], references: [id])

  body      String
  createdAt DateTime @default(now())
}

enum Role {
  HIRER
  WORKER
}

enum BudgetType {
  FIXED
  HOURLY
}

enum JobStatus {
  OPEN
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  CANCELED
}

enum AppStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum BookingStatus {
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  DISPUTED
  REFUNDED
  PAID
}
